# Apache-Konfiguration für Schreinerei Krickl Website
# Für Mittwald-Hosting optimiert

# Aktiviere Rewrite-Engine
RewriteEngine On

# HTTPS-Weiterleitung (optional - Mittwald macht das oft automatisch)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# SPA-Routing: Alle nicht-existierenden Pfade zur index.html weiterleiten
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} !^/api/
RewriteRule ^(.*)$ /index.html [L]

# Caching für statische Assets
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Bilder - 1 Jahr
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    
    # CSS und JavaScript - 1 Jahr (wegen Hash im Dateinamen)
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    
    # Fonts - 1 Jahr
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    
    # HTML - 1 Stunde
    ExpiresByType text/html "access plus 1 hour"
</IfModule>

# Komprimierung aktivieren
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# Sicherheitsheader
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# PHP-Konfiguration siehe .user.ini (für PHP-FPM auf Mittwald)
